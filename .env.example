# Example environment file for AegisGraph Sentinel 2.0
#
# 12-Factor App principles:
# - Config is environment-specific and injected via environment variables.
# - Environment variables override defaults and any YAML config.
# - Use consistent naming so the same app works across dev/stage/prod.
#
# Copy this file to `.env` and update values as needed.

# =========================
# API (service) settings
# =========================
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
API_URL=http://localhost:8000
LOG_LEVEL=INFO
LOG_FORMAT=json

# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Legacy alias for CORS_ORIGINS (optional; CORS_ORIGINS takes priority)
# AEGIS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# Rate limit in the format: <number>/<unit> (e.g., 500/minute)
RATE_LIMIT=1000/minute

# Batch / chunk sizing
MAX_BATCH_SIZE=100

# =========================
# Risk thresholds (0-1)
# Ordered so: allow <= review <= block
# =========================
RISK_THRESHOLD_ALLOW=0.40
RISK_THRESHOLD_REVIEW=0.65
RISK_THRESHOLD_BLOCK=0.85

# =========================
# Component weights (should sum to ~1.0)
# =========================
COMPONENT_WEIGHT_GRAPH=0.50
COMPONENT_WEIGHT_VELOCITY=0.20
COMPONENT_WEIGHT_BEHAVIOR=0.20
COMPONENT_WEIGHT_ENTROPY=0.10

# =========================
# Optional: feature flags / integrations
# =========================
# AEGIS_NEO4J_ENABLED=false
# AEGIS_NEO4J_URI=bolt://localhost:7687
# AEGIS_NEO4J_USER=neo4j
# AEGIS_NEO4J_PASSWORD=changeme

# Google Gemini API Key for AI Alert Summaries
# GEMINI_API_KEY=your_gemini_api_key_here

# =========================
# Real-Time Webhook Integrations  (Issue #633)
# =========================
#
# AegisGraph Sentinel can send real-time notifications to Discord and/or
# Slack whenever a HIGH-severity SentinelAlertEvent is emitted — for example
# when a fraud transaction is automatically blocked.
#
# Global kill-switch: set to "false" to silence all webhook notifications
# regardless of per-service settings below.
ENABLE_WEBHOOK_ALERTS=false

# --- Discord ---
# 1. In your Discord server → channel settings → Integrations → Webhooks.
# 2. Create or copy a Webhook URL (format: https://discord.com/api/webhooks/<id>/<token>).
# 3. Set ENABLE_DISCORD_WEBHOOK=true to activate.
DISCORD_WEBHOOK_URL=
ENABLE_DISCORD_WEBHOOK=false

# --- Slack ---
# 1. Visit https://api.slack.com/apps → Your App → Incoming Webhooks.
# 2. Activate incoming webhooks, add to workspace, copy the Webhook URL.
#    (format: https://hooks.slack.com/services/<T>/<B>/<token>)
# 3. Set ENABLE_SLACK_WEBHOOK=true to activate.
SLACK_WEBHOOK_URL=
ENABLE_SLACK_WEBHOOK=false
