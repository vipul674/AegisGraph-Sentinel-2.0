# API Configuration
API_URL=http://localhost:8000

# CORS Configuration (comma-separated origins)
AEGIS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501,http://127.0.0.1:8501

# Debug Mode (set to 'true' to enable debug endpoints)
DEBUG=false

# Logging Level
LOG_LEVEL=INFO

# Computation Device (cpu, cuda, or mps)
DEVICE=cpu

# Model Path
MODEL_PATH=models/htgnn_best.pt

# GPU Configuration
CUDA_VISIBLE_DEVICES=0

# Neo4j Database Credentials
# Use encrypted schemes (neo4j+ssc:// or neo4j+s://) for production
AEGIS_NEO4J_URI=neo4j+ssc://localhost:7687
AEGIS_NEO4J_USER=neo4j
AEGIS_NEO4J_PASSWORD=your_secure_password
# Set to false to allow unencrypted connections (not recommended for production)
AEGIS_NEO4J_REQUIRE_ENCRYPTION=true
